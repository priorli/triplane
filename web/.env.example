# Triplane web — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# `bun run build` will fail without the Clerk keys at minimum.

# --- Database (Neon serverless Postgres) ---
# Get these from https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Clerk auth ---
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Optional: only needed if you wire up the Clerk webhook for user.created/updated events
CLERK_WEBHOOK_SECRET="whsec_..."

# --- App URL ---
# Used in absolute URLs (e.g. webhooks). Use http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Tigris (Fly.io S3-compatible storage) ---
# Get these from `fly storage create` after `fly launch`.
# Only required when you start using file uploads (Phase 4: items + photos).
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="auto"
AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
TIGRIS_BUCKET_NAME="..."

# Upload strategy: "presign" (production, requires CORS) or "proxy" (dev/staging, server-side upload)
NEXT_PUBLIC_UPLOAD_STRATEGY="proxy"
