# Triplane web — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# `bun run build` will fail without the Clerk keys at minimum.

# --- Database (Neon serverless Postgres) ---
# Get these from https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Clerk auth ---
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Optional: only needed if you wire up the Clerk webhook for user.created/updated events
CLERK_WEBHOOK_SECRET="whsec_..."

# --- App URL ---
# Used in absolute URLs (e.g. webhooks). Use http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Tigris (Fly.io S3-compatible storage) ---
# Get these from `fly storage create` after `fly launch`.
# Required for the items + photos feature. Bucket should be private —
# all reads and writes flow through server-issued presigned URLs.
# For local dev, either `fly storage create` or any S3-compatible service works
# (e.g., MinIO, LocalStack).
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="auto"
AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
TIGRIS_BUCKET_NAME="..."

# --- Downstream external APIs (add per-project) ---
# When /feature or /init-app adds code that calls process.env.SOME_API_KEY,
# add the variable here with a comment explaining where to get it.
# Features that use /stub-external-api can run without real keys — the stub
# returns Faker-powered responses when the key is unset.
#
# Example (Tableau — used by the analytics-dashboards feature):
# TABLEAU_SERVER_URL="https://tableau.yourcompany.com"
# TABLEAU_SITE_ID="your-site-content-url"
# TABLEAU_CLIENT_ID="your-connected-app-client-id"
# TABLEAU_SECRET_VALUE="your-connected-app-secret-value"

# --- Triplane Forge authentication (forge branch only) ---
# By default, forge runs shell out to the local `claude` CLI and use your
# Claude Code subscription (no API credits burned; counts against your Max
# rate-limit window, which is separate from the API quota). Prereqs:
# - `claude` in PATH (https://claude.com/claude-code)
# - Previously ran `claude login` on this machine
#
# Set FORGE_USE_SDK=1 to opt into the Agent SDK fallback instead. Costs API
# credits but preserves per-tool browser approvals via the canUseTool hook
# (the CLI path currently runs with --permission-mode bypassPermissions
# because Claude Code 2.1.101 has no --permission-prompt-tool flag).
# FORGE_USE_SDK=1
# ANTHROPIC_API_KEY="sk-ant-..."

# --- Triplane Forge skills overlay (forge branch only) ---
# When a new forge session worktree is created from `main`, this env var
# overlays `.claude/skills/` from a different branch so the worktree has
# access to forge-only skills like /plan-autoplan, /seed-demo, and
# /stub-external-api (which live on the forge branch and were never merged
# to main). Default: "forge". Set to "" to disable the overlay entirely.
# FORGE_SKILLS_BRANCH="forge"

# --- Triplane Forge editor auto-open (forge branch only) ---
# When a new forge session creates its worktree, open it in your editor
# automatically. Defaults to `code` (VS Code). Override for other editors:
#   FORGE_EDITOR_COMMAND="cursor"         # Cursor
#   FORGE_EDITOR_COMMAND="code-insiders"  # VS Code Insiders
#   FORGE_EDITOR_COMMAND="windsurf"       # Windsurf
#   FORGE_EDITOR_COMMAND="idea"           # IntelliJ / JetBrains
#   FORGE_EDITOR_COMMAND="subl"           # Sublime Text
# Set to an empty string to disable auto-open entirely:
#   FORGE_EDITOR_COMMAND=""
# If the editor binary isn't in PATH, the spawn fails silently with a
# server-console warning — the forge session is never blocked by editor
# issues. For VS Code, run "Shell Command: Install 'code' command in PATH"
# from the Command Palette once to get `code` wired up.
